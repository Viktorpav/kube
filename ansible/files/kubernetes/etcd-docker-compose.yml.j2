version: '3.8'
services:
  etcd:
    image: quay.io/coreos/etcd:v3.5.16{% if ansible_architecture == 'aarch64' or ansible_architecture == 'arm64' %}-arm64{% endif %}
    container_name: etcd-{{ inventory_hostname }}
    restart: always
    network_mode: host
    volumes:
      - ./data:/etcd-data
      - ./certs:/etc/kubernetes/pki/etcd
    command:
      - /usr/local/bin/etcd
      - --name={{ inventory_hostname }}
      - --data-dir=/etcd-data
      - --listen-peer-urls=https://0.0.0.0:2380
      - --listen-client-urls=https://0.0.0.0:2379
      - --advertise-client-urls=https://{{ hostvars[inventory_hostname]['ansible_host'] | default('192.168.0.12') }}:2379
      - --initial-advertise-peer-urls=https://{{ hostvars[inventory_hostname]['ansible_host'] | default('192.168.0.12') }}:2380
      - --initial-cluster={% for host in groups['etcd_nodes'] %}{{ hostvars[host].inventory_hostname }}=https://{% if host == 'mac-etcd' %}{{ hostvars[host]['ansible_host'] | default('192.168.0.12') }}{% else %}{{ hostvars[host]['ansible_default_ipv4']['address'] }}{% endif %}:2380{% if not loop.last %},{% endif %}{% endfor %}
      
      - --initial-cluster-token=etcd-cluster-token
      - --initial-cluster-state={{ etcd_cluster_state }}
      - --cert-file=/etc/kubernetes/pki/etcd/{{ inventory_hostname }}.crt
      - --key-file=/etc/kubernetes/pki/etcd/{{ inventory_hostname }}.key
      - --trusted-ca-file=/etc/kubernetes/pki/etcd/ca.crt
      - --client-cert-auth=true
      - --peer-cert-file=/etc/kubernetes/pki/etcd/{{ inventory_hostname }}-peer.crt
      - --peer-key-file=/etc/kubernetes/pki/etcd/{{ inventory_hostname }}-peer.key
      - --peer-trusted-ca-file=/etc/kubernetes/pki/etcd/ca.crt
      - --peer-client-cert-auth=true
      - --enable-v2=false
      - --logger=zap
      - --log-outputs=stderr
      - --log-level=info